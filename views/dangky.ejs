<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <title>Đăng ký tài khoản - LeMinhStudio</title>
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f4f6f9;
            color: #333;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card-modern {
            border: none;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            width: 100%;
            max-width: 500px; /* Form đăng ký rộng hơn đăng nhập một chút */
        }

        .card-header-modern {
            background-color: #4361ee; 
            color: #ffffff;
            font-weight: 600;
            border-top-left-radius: 12px !important;
            border-top-right-radius: 12px !important;
            border-bottom: none;
            padding: 20px;
            text-align: center;
        }

        .btn-custom {
            border-radius: 8px;
            font-weight: 600;
            padding: 12px;
        }
        
        .form-control-custom {
            border-radius: 8px;
            background-color: #f8f9fa;
            border: 1px solid #e9ecef;
        }
        .form-control-custom:focus {
            background-color: #fff;
            border-color: #4361ee;
            box-shadow: 0 0 0 0.25rem rgba(67, 97, 238, 0.25);
        }
    </style>
</head>
<body>
    <div class="container d-flex flex-column align-items-center">
        
        <div class="fw-bold mb-4 fs-2 text-primary">
            <i class="bi bi-layers-fill me-1"></i> LeMinhStudio
        </div>

        <div class="card card-modern">
            <div class="card-header card-header-modern">
                <h5 class="mb-0 text-uppercase">Tạo tài khoản mới</h5>
            </div>
            <div class="card-body p-4">
                <form action="/dangky" method="POST" class="needs-validation" novalidate>
                    
                    <div class="mb-3">
                        <label class="form-label fw-medium small text-muted">Họ và tên</label>
                        <input type="text" class="form-control form-control-custom" name="HoVaTen" placeholder="Nhập tên đầy đủ của bạn..." required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-medium small text-muted">Email liên hệ</label>
                        <input type="email" class="form-control form-control-custom" name="Email" placeholder="email@vi-du.com" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-medium small text-muted">Tên đăng nhập</label>
                        <input type="text" class="form-control form-control-custom" name="TenDangNhap" placeholder="Viết liền không dấu..." required>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium small text-muted">Mật khẩu</label>
                            <input type="password" class="form-control form-control-custom" name="MatKhau" required>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-medium small text-muted">Xác nhận lại</label>
                            <input type="password" class="form-control form-control-custom" name="XacNhanMatKhau" required>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary btn-custom w-100 mb-3 shadow-sm">
                        Đăng ký ngay
                    </button>
                </form>
                
                <div class="text-center mt-2">
                    <span class="text-muted small">Đã có tài khoản?</span> 
                    <a href="/dangnhap" class="text-decoration-none fw-semibold" style="color: #4361ee;">Đăng nhập</a>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Kiểm tra validate của Bootstrap
        (function() {
            'use strict';
            const forms = document.querySelectorAll('.needs-validation');
            Array.from(forms).forEach(form => {
                form.addEventListener('submit', event => {
                    if (!form.checkValidity()) {
                        event.preventDefault();
                        event.stopPropagation();
                    }
                    form.classList.add('was-validated');
                }, false);
            });
        })();
    </script>
</body>
</html>
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <title><%= title %></title>
    <style>body { font-family: 'Inter', sans-serif; background-color: #f4f6f9; }</style>
</head>
<body class="d-flex align-items-center justify-content-center vh-100">
    <div class="card shadow-sm" style="width: 500px; border-radius: 12px; border: none;">
        <div class="card-header bg-warning text-dark fw-bold py-3" style="border-radius: 12px 12px 0 0;">
            <%= title %>
        </div>
        <div class="card-body p-4">
            <form action="/taikhoan/sua/<%= nv._id %>" method="POST">
                <div class="mb-3">
                    <label>Tên đăng nhập (Không thể sửa)</label>
                    <input type="text" class="form-control" value="<%= nv.TenDangNhap %>" disabled>
                </div>
                <div class="mb-3">
                    <label>Họ và tên</label>
                    <input type="text" name="HoVaTen" class="form-control" value="<%= nv.HoVaTen %>" required>
                </div>
                <div class="mb-3">
                    <label>Email</label>
                    <input type="email" name="Email" class="form-control" value="<%= nv.Email %>" required>
                </div>
                <div class="mb-4">
                    <label>Chức vụ (Quyền hạn)</label>
                    <select name="QuyenHan" class="form-select">
                        <option value="user" <%= nv.QuyenHan === 'user' ? 'selected' : '' %>>Nhân viên (User)</option>
                        <option value="admin" <%= nv.QuyenHan === 'admin' ? 'selected' : '' %>>Quản lý (Admin)</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-warning w-100 fw-bold">Cập nhật thông tin</button>
                <a href="/taikhoan" class="btn btn-light w-100 mt-2 text-muted">Hủy & Quay lại</a>
            </form>
        </div>
    </div>
</body>
</html>